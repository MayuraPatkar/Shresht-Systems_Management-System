{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "outDir": "./dist/public",
        "rootDir": "./public",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitReturns": false,
        "sourceMap": true,
        "declaration": true,
        "removeComments": false,
        "composite": true
    },
    "include": [
        "public/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src"
    ]
}